# Vorlage fuer lokale Secrets. Kopieren nach `.env` (gitignored) und ausfuellen.
# tessera laedt diese Datei NICHT automatisch — vor dem Lauf sourcen:
#   set -a; source .env; set +a
#
# Keys werden niemals committet oder geloggt (Credentials-Grenze, CLAUDE.md).

# LLM-Provider-Key fuer die Extraktion (passend zum Modell unten).
ANTHROPIC_API_KEY=

# pydantic-ai-Modellstring (optional; Default: anthropic:claude-opus-4-8).
# TESSERA_MODEL=anthropic:claude-opus-4-8

# GitHub-Token mit Schreibrecht auf das ZIEL-Repo (maschinerie-zuerich):
# Contents: Read and write + Pull requests: Read and write.
# Ohne Token landet das PR-Bundle in out/outbox/<id>/.
GITHUB_TOKEN=

# Ziel-Repo fuer die Draft-PRs (optional; Default: malkreide/maschinerie-zuerich).
# TARGET_REPO=malkreide/maschinerie-zuerich
